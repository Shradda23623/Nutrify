rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users collection ───────────────────────────────────────────────────
    // Each user can only read/write their own document and sub-collections.

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // ── Sub-collections (all scoped to the owner) ──────────────────────

      match /calories/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /water/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /weight/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /measurements/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /sleep/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /workouts/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /fasting/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /meal_plans/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /custom_foods/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /micronutrients/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /streaks/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ── Deny everything else ────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
