# Auto-detect text files and normalize line endings to LF in the repo.
# Working-tree files keep their native line endings (CRLF on Windows, LF on Linux/macOS).
* text=auto eol=lf

# Source code — always LF
*.dart      text eol=lf
*.kt        text eol=lf
*.java      text eol=lf
*.swift     text eol=lf
*.cc        text eol=lf
*.cpp       text eol=lf
*.h         text eol=lf
*.m         text eol=lf
*.mm        text eol=lf

# Web
*.html      text eol=lf
*.css       text eol=lf
*.js        text eol=lf
*.ts        text eol=lf

# Config / data
*.yaml      text eol=lf
*.yml       text eol=lf
*.json      text eol=lf
*.xml       text eol=lf
*.gradle    text eol=lf
*.properties text eol=lf
*.cfg       text eol=lf
*.toml      text eol=lf

# Shell scripts must be LF (won't run with CRLF)
*.sh        text eol=lf

# Windows-only files keep CRLF
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf

# Binary files — never touch line endings
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.webp      binary
*.pdf       binary
*.zip       binary
*.tar       binary
*.gz        binary
*.jar       binary
*.apk       binary
*.aab       binary
*.keystore  binary
*.jks       binary
*.ttf       binary
*.otf       binary
*.woff      binary
*.woff2     binary
*.mp3       binary
*.mp4       binary
*.mov       binary
*.lottie    binary
